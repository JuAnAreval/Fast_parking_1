PORT=3000

# Local / generic variables
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=parqueaderos_db

# Optional TLS for MySQL providers
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Timezone controls
# DB_TIMEZONE is applied to each MySQL session (affects CURTIME/NOW/CURDATE)
DB_TIMEZONE=-05:00
# APP_TIMEZONE is used by Node when generating fallback date/time values
APP_TIMEZONE=America/Bogota

# Railway variables (can be referenced from Railway dashboard)
# DB_HOST=${{MYSQLHOST}}
# DB_PORT=${{MYSQLPORT}}
# DB_USER=${{MYSQLUSER}}
# DB_PASSWORD=${{MYSQLPASSWORD}}
# DB_NAME=${{MYSQLDATABASE}}

JWT_SECRET=replace_with_a_long_random_secret
USER_JWT_EXPIRES_IN=30d
